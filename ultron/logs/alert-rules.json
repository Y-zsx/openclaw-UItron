{
  "rules": [
    {
      "id": "cpu_low",
      "name": "CPU负载低",
      "enabled": true,
      "source": "cpu",
      "metric": "load_1m",
      "operator": "lt",
      "threshold": 0.1,
      "level": "info",
      "cooldown_minutes": 30,
      "aggregation_window": 5,
      "notify_channels": ["console"]
    },
    {
      "id": "cpu_normal",
      "name": "CPU负载正常",
      "enabled": true,
      "source": "cpu",
      "metric": "load_1m",
      "operator": "lte",
      "threshold": 50,
      "level": "info",
      "cooldown_minutes": 30,
      "aggregation_window": 5,
      "notify_channels": ["console"]
    },
    {
      "id": "cpu_warning",
      "name": "CPU负载偏高",
      "enabled": true,
      "source": "cpu",
      "metric": "load_1m",
      "operator": "gt",
      "threshold": 50,
      "level": "warning",
      "cooldown_minutes": 5,
      "aggregation_window": 3,
      "notify_channels": ["console"]
    },
    {
      "id": "cpu_high",
      "name": "CPU负载过高",
      "enabled": true,
      "source": "cpu",
      "metric": "load_1m",
      "operator": "gt",
      "threshold": 80,
      "level": "warning",
      "cooldown_minutes": 5,
      "aggregation_window": 5,
      "notify_channels": ["console"]
    },
    {
      "id": "cpu_critical",
      "name": "CPU负载严重过载",
      "enabled": true,
      "source": "cpu",
      "metric": "load_1m",
      "operator": "gt",
      "threshold": 95,
      "level": "critical",
      "cooldown_minutes": 2,
      "aggregation_window": 2,
      "notify_channels": ["console", "dingtalk"]
    },
    {
      "id": "memory_low",
      "name": "内存使用率低",
      "enabled": true,
      "source": "memory",
      "metric": "usage_percent",
      "operator": "lt",
      "threshold": 30,
      "level": "info",
      "cooldown_minutes": 60,
      "aggregation_window": 10,
      "notify_channels": ["console"]
    },
    {
      "id": "memory_normal",
      "name": "内存使用率正常",
      "enabled": true,
      "source": "memory",
      "metric": "usage_percent",
      "operator": "lte",
      "threshold": 60,
      "level": "info",
      "cooldown_minutes": 30,
      "aggregation_window": 10,
      "notify_channels": ["console"]
    },
    {
      "id": "memory_warning",
      "name": "内存使用率偏高",
      "enabled": true,
      "source": "memory",
      "metric": "usage_percent",
      "operator": "gt",
      "threshold": 60,
      "level": "warning",
      "cooldown_minutes": 5,
      "aggregation_window": 5,
      "notify_channels": ["console"]
    },
    {
      "id": "memory_high",
      "name": "内存使用率过高",
      "enabled": true,
      "source": "memory",
      "metric": "usage_percent",
      "operator": "gt",
      "threshold": 85,
      "level": "warning",
      "cooldown_minutes": 5,
      "aggregation_window": 5,
      "notify_channels": ["console"]
    },
    {
      "id": "memory_critical",
      "name": "内存使用率严重过高",
      "enabled": true,
      "source": "memory",
      "metric": "usage_percent",
      "operator": "gt",
      "threshold": 95,
      "level": "critical",
      "cooldown_minutes": 2,
      "aggregation_window": 2,
      "notify_channels": ["console", "dingtalk"]
    },
    {
      "id": "disk_low",
      "name": "磁盘使用率低",
      "enabled": true,
      "source": "disk",
      "metric": "usage_percent",
      "operator": "lt",
      "threshold": 50,
      "level": "info",
      "cooldown_minutes": 120,
      "aggregation_window": 30,
      "notify_channels": ["console"]
    },
    {
      "id": "disk_normal",
      "name": "磁盘使用率正常",
      "enabled": true,
      "source": "disk",
      "metric": "usage_percent",
      "operator": "lte",
      "threshold": 70,
      "level": "info",
      "cooldown_minutes": 60,
      "aggregation_window": 30,
      "notify_channels": ["console"]
    },
    {
      "id": "disk_warning",
      "name": "磁盘使用率偏高",
      "enabled": true,
      "source": "disk",
      "metric": "usage_percent",
      "operator": "gt",
      "threshold": 70,
      "level": "warning",
      "cooldown_minutes": 10,
      "aggregation_window": 10,
      "notify_channels": ["console"]
    },
    {
      "id": "disk_high",
      "name": "磁盘使用率过高",
      "enabled": true,
