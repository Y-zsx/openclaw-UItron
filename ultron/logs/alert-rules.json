      "metric": "usage_percent",
      "operator": "gt",
      "threshold": 85,
      "level": "warning",
      "cooldown_minutes": 10,
      "aggregation_window": 10,
      "notify_channels": ["console", "dingtalk"]
    },
    {
      "id": "disk_critical",
      "name": "磁盘空间不足",
      "enabled": true,
      "source": "disk",
      "metric": "usage_percent",
      "operator": "gt",
      "threshold": 95,
      "level": "critical",
      "cooldown_minutes": 5,
      "aggregation_window": 5,
      "notify_channels": ["console", "dingtalk"]
    },
    {
      "id": "disk_critical_bytes",
      "name": "磁盘可用空间不足",
      "enabled": true,
      "source": "disk",
      "metric": "available_bytes",
      "operator": "lt",
      "threshold": 1073741824,
      "level": "critical",
      "cooldown_minutes": 5,
      "aggregation_window": 5,
      "notify_channels": ["console", "dingtalk"]
    },
    {
      "id": "service_down",
      "name": "服务宕机",
      "enabled": true,
      "source": "services",
      "metric": "status",
      "operator": "eq",
      "threshold": 0,
      "level": "critical",
      "cooldown_minutes": 2,
      "aggregation_window": 2,
      "notify_channels": ["console", "dingtalk"]
    },
    {
      "id": "process_high",
      "name": "进程数过多",
      "enabled": true,
      "source": "processes",
      "metric": "count",
      "operator": "gt",
      "threshold": 300,
      "level": "warning",
      "cooldown_minutes": 10,
      "aggregation_window": 10,
      "notify_channels": ["console"]
    }
