[Unit]
Description=Agent Orchestrator Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace/ultron/tools/orchestrator
ExecStart=/usr/bin/python3 /root/.openclaw/workspace/ultron/tools/orchestrator/orchestrator_api.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target