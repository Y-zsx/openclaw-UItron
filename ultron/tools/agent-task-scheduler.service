[Unit]
Description=Agent Task Scheduler Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace/ultron/tools
ExecStart=/usr/bin/python3 /root/.openclaw/workspace/ultron/tools/agent_task_scheduler.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target