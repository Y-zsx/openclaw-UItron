        elif sys.argv[1] == "history":
            init_db()
            history = get_heal_history()
            print(json.dumps(history, indent=2))
    else:
        init_db()
        # 默认运行治愈周期
        results = auto_heal_cycle()
        print(json.dumps(results, indent=2))