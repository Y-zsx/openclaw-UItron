[Unit]
Description=Ultron Collaboration Enhanced API
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace/ultron/agents
ExecStart=/usr/bin/python3 /root/.openclaw/workspace/ultron/agents/collab_enhanced_api.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target